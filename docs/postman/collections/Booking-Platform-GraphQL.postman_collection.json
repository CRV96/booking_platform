									"        pm.expect(roles).to.include('employee');",
									"    });",
									"} else {",
									"    pm.test('Employee login failed', function() {",
									"        pm.expect.fail(JSON.stringify(jsonData.errors));",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n    refreshExpiresIn\n    tokenType\n    user {\n      id\n      username\n      email\n      firstName\n      lastName\n      roles\n    }\n  }\n}",
								"variables": "{\n  \"input\": {\n    \"username\": \"jane.organizer\",\n    \"password\": \"employee123\"\n  }\n}"
