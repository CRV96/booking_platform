{
	"info": {
		"_postman_id": "booking-platform-graphql",
		"name": "Booking Platform - GraphQL API",
		"description": "GraphQL API for the Booking Platform microservices",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "1. Register New User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.register) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.register.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.register.refreshToken);",
									"    if (jsonData.data.register.user) {",
									"        pm.collectionVariables.set('userId', jsonData.data.register.user.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation Register($input: RegisterInput!) {\n  register(input: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n    refreshExpiresIn\n    tokenType\n    user {\n      id\n      email\n      firstName\n      lastName\n      emailVerified\n    }\n  }\n}",
								"variables": "{\n  \"input\": {\n    \"email\": \"test.user@example.com\",\n    \"password\": \"Test123!\",\n    \"firstName\": \"Test\",\n    \"lastName\": \"User\",\n    \"phoneNumber\": \"+1234567890\",\n    \"country\": \"US\",\n    \"preferredLanguage\": \"en\"\n  }\n}"
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "2. Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.login) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.login.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.login.refreshToken);",
									"    if (jsonData.data.login.user) {",
									"        pm.collectionVariables.set('userId', jsonData.data.login.user.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n    refreshExpiresIn\n    tokenType\n    user {\n      id\n      username\n      email\n      firstName\n      lastName\n      emailVerified\n      roles\n    }\n  }\n}",
								"variables": "{\n  \"input\": {\n    \"username\": \"john.doe\",\n    \"password\": \"customer123\"\n  }\n}"
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "3. Login (with email)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.login) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.login.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.login.refreshToken);",
									"    if (jsonData.data.login.user) {",
									"        pm.collectionVariables.set('userId', jsonData.data.login.user.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n    refreshExpiresIn\n    tokenType\n    user {\n      id\n      username\n      email\n      firstName\n      lastName\n      emailVerified\n    }\n  }\n}",
								"variables": "{\n  \"input\": {\n    \"username\": \"test.user@example.com\",\n    \"password\": \"Test123!\"\n  }\n}"
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "4. Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.refreshToken) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.refreshToken.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation RefreshToken($refreshToken: String!) {\n  refreshToken(refreshToken: $refreshToken) {\n    accessToken\n    refreshToken\n    expiresIn\n    refreshExpiresIn\n    tokenType\n  }\n}",
								"variables": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "5. Logout",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.logout && jsonData.data.logout.success) {",
									"    pm.collectionVariables.set('accessToken', '');",
									"    pm.collectionVariables.set('refreshToken', '');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation Logout($refreshToken: String!) {\n  logout(refreshToken: $refreshToken) {\n    success\n  }\n}",
								"variables": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Get User by ID",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "query GetUser($id: ID!) {\n  user(id: $id) {\n    id\n    username\n    email\n    emailVerified\n    enabled\n    firstName\n    lastName\n    createdAt\n    phoneNumber\n    country\n    preferredLanguage\n    roles\n  }\n}",
								"variables": "{\n  \"id\": \"{{userId}}\"\n}"
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "Search Users",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "query SearchUsers($query: String, $page: Int, $pageSize: Int) {\n  users(query: $query, page: $page, pageSize: $pageSize) {\n    users {\n      id\n      username\n      email\n      firstName\n      lastName\n      emailVerified\n    }\n    totalCount\n    page\n    pageSize\n    totalPages\n  }\n}",
								"variables": "{\n  \"query\": \"john\",\n  \"page\": 0,\n  \"pageSize\": 10\n}"
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "List All Users",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "query ListAllUsers {\n  users(page: 0, pageSize: 20) {\n    users {\n      id\n      username\n      email\n      firstName\n      lastName\n      emailVerified\n      enabled\n    }\n    totalCount\n    page\n    pageSize\n    totalPages\n  }\n}",
								"variables": ""
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "Get Current User (me)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "query Me {\n  me {\n    id\n    username\n    email\n    firstName\n    lastName\n    emailVerified\n    roles\n  }\n}",
								"variables": ""
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				}
			]
		},
		{
			"name": "Health Checks",
			"item": [
				{
					"name": "GraphQL Schema Introspection",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "{\n  __schema {\n    types {\n      name\n    }\n  }\n}",
								"variables": ""
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "Simple Query Test",
					"request": {
