{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Booking Platform — Logs, Metrics & Health for all microservices",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔍 Live Logs",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{job=\"microservices\", service=~\"$service\", service!~\"$exclude\"} |= \"$search\"",
          "refId": "A"
        }
      ],
      "title": "Service Logs",
      "type": "logs"
    },

    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 11 },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{job=\"microservices\"} | level=\"ERROR\"",
          "refId": "A"
        }
      ],
      "title": "🔴 Errors Only (all services)",
      "type": "logs"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 101,
      "title": "📊 Log Volume",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 20 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARN" },  "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" },  "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "DEBUG" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (level) (count_over_time({job=\"microservices\", service=~\"$service\"}[$__interval]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "title": "Log Volume by Level",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (service) (count_over_time({job=\"microservices\"}[$__interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Log Volume by Service",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 102,
      "title": "🚦 Health & Uptime",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 29 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "up{job=\"graphql-gateway\"}", "legendFormat": "graphql-gateway", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "up{job=\"user-service\"}", "legendFormat": "user-service", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "up{job=\"event-service\"}", "legendFormat": "event-service", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "up{job=\"booking-service\"}", "legendFormat": "booking-service", "refId": "D" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "up{job=\"payment-service\"}", "legendFormat": "payment-service", "refId": "E" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "up{job=\"ticket-service\"}", "legendFormat": "ticket-service", "refId": "F" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "up{job=\"notification-service\"}", "legendFormat": "notification-service", "refId": "G" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "up{job=\"analytics-service\"}", "legendFormat": "analytics-service", "refId": "H" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "up{job=\"eureka-service\"}", "legendFormat": "eureka-service", "refId": "I" }
      ],
      "title": "Service Status (UP / DOWN)",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 103,
      "title": "⚡ JVM Memory",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\", job=~\"$service\"})",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "JVM Heap Used",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "id": 7,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "jvm_threads_live_threads{job=~\"$service\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "JVM Live Threads",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 104,
      "title": "🌐 HTTP Requests",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "id": 8,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{job=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "id": 9,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_server_requests_seconds_bucket{job=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "{{job}} p95",
          "refId": "A"
        }
      ],
      "title": "HTTP Latency p95",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "id": 105,
      "title": "📨 Kafka Consumer Lag",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 52 },
      "id": 10,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "kafka_consumer_lag",
          "legendFormat": "{{topic}} p{{partition}}",
          "refId": "A"
        }
      ],
      "title": "Kafka Consumer Lag per Topic",
      "type": "timeseries"
    }

  ],

  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["booking-platform", "microservices"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "definition": "label_values({job=\"microservices\"}, service)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values({job=\"microservices\"}, service)",
        "refresh": 2,
        "type": "query",
        "label": "Service"
      },
      {
        "current": { "selected": true, "text": ["None"], "value": ["none____"] },
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "definition": "label_values({job=\"microservices\"}, service)",
        "hide": 0,
        "includeAll": false,
        "multi": true,
        "name": "exclude",
        "options": [],
        "query": "label_values({job=\"microservices\"}, service)",
        "refresh": 2,
        "type": "query",
        "label": "Exclude Service"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "name": "search",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "type": "textbox",
        "label": "Search logs"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Booking Platform",
  "uid": "booking-platform-main",
  "version": 3
}
