{
  "realm": "booking-platform",
  "enabled": true,
  "sslRequired": "none",

  "attributes": {
    "userProfileEnabled": "true"
  },

  "clients": [
    {
      "clientId": "booking-app",
      "name": "Booking Platform App",
      "description": "Public client for user login (Postman, Frontend)",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:8080"],
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"],
      "optionalClientScopes": ["phone", "address", "offline_access"],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "phone-number",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "claim.name": "phone_number",
            "user.attribute": "phoneNumber",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        },
        {
          "name": "country",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "claim.name": "country",
            "user.attribute": "country",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    }
  ],

  "roles": {
    "realm": [
      {
        "name": "employee",
        "description": "Employee role"
      },
      {
        "name": "customer",
        "description": "Customer role"
      }
    ]
  },

  "groups": [
    {
      "name": "employees",
      "realmRoles": ["employee"]
    },
    {
      "name": "customers",
      "realmRoles": ["customer"]
    }
  ],

  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Employee",
      "lastName": "Admin",
      "email": "employee.admin@booking.com",

      "attributes": {
        "phoneNumber": ["+1234567890"],
        "country": ["US"],
        "preferredLanguage": ["en"],
        "dateOfBirth": ["1990-01-15"],
        "billingAddress": ["123 Admin Street, New York, NY 10001"],
        "profilePictureUrl": [""]
      },

      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],

      "groups": [
        "/employees"
      ],

      "clientRoles": {
        "realm-management": [
          "realm-admin",
          "manage-realm",
          "manage-users",
          "manage-clients",
          "manage-identity-providers",
          "manage-authorization",
          "manage-events",
          "view-realm",
          "view-users",
          "view-identity-providers",
          "view-authorization",
          "view-events",
          "query-users"
        ],
        "account": [
          "view-profile",
          "manage-account"
        ]
      }
    },
    {
      "username": "john.doe",
      "enabled": true,
      "emailVerified": true,
      "firstName": "John",
      "lastName": "Doe",
      "email": "john.doe@example.com",
      "attributes": {
        "phoneNumber": ["+1555123456"],
        "country": ["US"],
        "preferredLanguage": ["en"],
        "dateOfBirth": ["1985-06-20"],
        "billingAddress": ["456 Oak Street, Los Angeles, CA 90001"],
        "profilePictureUrl": [""]
      },
      "credentials": [
        {
          "type": "password",
          "value": "customer123",
          "temporary": false
        }
      ],
      "groups": ["/customers"],
      "clientRoles": {
        "account": ["view-profile", "manage-account"]
      }
    },
    {
      "username": "jane.smith",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Jane",
      "lastName": "Smith",
      "email": "jane.smith@example.com",
      "attributes": {
        "phoneNumber": ["+44789123456"],
        "country": ["UK"],
        "preferredLanguage": ["en"],
        "dateOfBirth": ["1992-03-15"],
        "billingAddress": ["10 Baker Street, London, W1U 3BW"],
        "profilePictureUrl": [""]
      },
      "credentials": [
        {
          "type": "password",
          "value": "customer123",
          "temporary": false
        }
      ],
      "groups": ["/customers"],
      "clientRoles": {
        "account": ["view-profile", "manage-account"]
      }
    },
    {
      "username": "carlos.garcia",
      "enabled": true,
