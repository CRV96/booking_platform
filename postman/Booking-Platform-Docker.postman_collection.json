		{
			"name": "3. Eureka Service Registry",
			"description": "Verify all services registered with Eureka.",
			"item": [
				{
					"name": "Eureka Applications (all registered services)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Eureka returns registered apps', function() {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.applications).to.have.property('application');",
									"    var apps = jsonData.applications.application;",
									"    pm.expect(apps).to.be.an('array');",
									"    var appNames = apps.map(function(a) { return a.name; });",
									"    console.log('Registered services:', appNames.join(', '));",
									"});",
									"",
									"pm.test('All 9 services are registered', function() {",
									"    var jsonData = pm.response.json();",
									"    var apps = jsonData.applications.application;",
									"    var appNames = apps.map(function(a) { return a.name; });",
									"    var expected = [",
									"        'GRAPHQL-GATEWAY', 'USER-SERVICE', 'EVENT-SERVICE',",
									"        'BOOKING-SERVICE', 'PAYMENT-SERVICE', 'NOTIFICATION-SERVICE',",
									"        'ANALYTICS-SERVICE', 'TICKET-SERVICE', 'EUREKA-SERVICE'",
									"    ];",
									"    expected.forEach(function(name) {",
									"        pm.expect(appNames).to.include(name);",
									"    });",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
