							"protocol": "http",
							"host": ["localhost"],
							"port": "8761",
							"path": ["eureka", "apps"]
						}
					}
				}
			]
		},
		{
			"name": "4. GraphQL API (via Docker)",
			"description": "End-to-end GraphQL API tests running through the Dockerized services.\nIdentical to the local collection — the gateway is on the same port (8080).\n\nRecommended order:\n1. Login (customer or employee)\n2. Run queries/mutations as needed",
			"item": [
				{
					"name": "Schema Introspection",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('GraphQL schema is accessible', function() {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('__typename');",
									"    pm.expect(jsonData.data.__typename).to.eql('Query');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "{ __typename }",
								"variables": ""
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "Login (customer)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.login) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.login.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.login.refreshToken);",
									"    if (jsonData.data.login.user) {",
									"        pm.collectionVariables.set('userId', jsonData.data.login.user.id);",
									"    }",
									"    pm.test('Login successful', function() {",
									"        pm.expect(jsonData.data.login.accessToken).to.be.a('string');",
									"        pm.expect(jsonData.data.login.tokenType).to.eql('Bearer');",
									"    });",
									"} else {",
									"    pm.test('Login failed', function() {",
									"        pm.expect.fail(JSON.stringify(jsonData.errors));",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n    refreshExpiresIn\n    tokenType\n    user {\n      id\n      username\n      email\n      firstName\n      lastName\n      emailVerified\n      roles\n    }\n  }\n}",
								"variables": "{\n  \"input\": {\n    \"username\": \"john.doe\",\n    \"password\": \"customer123\"\n  }\n}"
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "Login (employee)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.login) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.login.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.login.refreshToken);",
									"    if (jsonData.data.login.user) {",
									"        pm.collectionVariables.set('userId', jsonData.data.login.user.id);",
									"    }",
									"    pm.test('Employee login successful', function() {",
									"        pm.expect(jsonData.data.login.accessToken).to.be.a('string');",
									"        pm.expect(jsonData.data.login.user.roles).to.include('employee');",
									"    });",
									"} else {",
									"    pm.test('Employee login failed', function() {",
									"        pm.expect.fail(JSON.stringify(jsonData.errors));",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n    tokenType\n    user {\n      id\n      username\n      email\n      firstName\n      lastName\n      roles\n    }\n  }\n}",
								"variables": "{\n  \"input\": {\n    \"username\": \"jane.organizer\",\n    \"password\": \"employee123\"\n  }\n}"
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "Get Current User (me)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.test('me query returns authenticated user', function() {",
									"    pm.expect(jsonData.data).to.have.property('me');",
									"    pm.expect(jsonData.data.me).to.have.property('id');",
									"    pm.expect(jsonData.data.me).to.have.property('email');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "query Me {\n  me {\n    id\n    username\n    email\n    firstName\n    lastName\n    roles\n  }\n}",
								"variables": ""
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": ["{{baseUrl}}"],
							"path": ["graphql"]
						}
					}
				},
				{
					"name": "List Events",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.test('Events list returned', function() {",
									"    pm.expect(jsonData.data).to.have.property('events');",
									"    pm.expect(jsonData.data.events.events).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "query ListEvents($page: Int, $pageSize: Int) {\n  events(page: $page, pageSize: $pageSize) {\n    events {\n      id\n      title\n      category\n      status\n      dateTime\n      venue {\n        name\n        city\n        country\n      }\n    }\n    totalCount\n    page\n    pageSize\n    totalPages\n  }\n}",
								"variables": "{\n  \"page\": 0,\n  \"pageSize\": 10\n}"
